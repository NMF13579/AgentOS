{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": ["task"]
    },
    {
      "required": [
        "task_id",
        "task_number",
        "task_name",
        "milestone",
        "state",
        "mode",
        "repository",
        "branch"
      ]
    }
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_number": {
      "type": "string",
      "minLength": 1
    },
    "task_name": {
      "type": "string",
      "minLength": 1
    },
    "milestone": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "scope_control": {
      "type": "object"
    },
    "activated_at": {},
    "activated_by": {
      "type": "string",
      "minLength": 1
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "source_task": {
      "type": "string",
      "minLength": 1
    },
    "source_contract": {
      "type": "string",
      "minLength": 1
    },
    "transition": {
      "type": "string",
      "minLength": 1
    },
    "execution_role": {
      "type": "object",
      "required": [
        "role",
        "mode",
        "allowed_write_paths",
        "forbidden_write_paths",
        "may_modify_files",
        "may_approve",
        "may_change_task_state",
        "may_create_handoff"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["planner", "implementor", "auditor", "verifier", "tutor", "researcher", "maintainer"]
        },
        "mode": {
          "type": "string",
          "enum": ["read_only", "scoped_write", "explain_only", "research_only", "maintenance_scoped"]
        },
        "allowed_write_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_write_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "may_modify_files": { "type": "boolean" },
        "may_approve": { "type": "boolean" },
        "may_change_task_state": { "type": "boolean" },
        "may_create_handoff": { "type": "boolean" }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "goal",
        "expected_result",
        "in_scope",
        "out_of_scope",
        "files_or_areas",
        "risk_level",
        "risk_reason",
        "requires_owner_approval",
        "rollback_plan",
        "acceptance_criteria",
        "verification_plan"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_or_areas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_level": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "risk_reason": {
          "type": "string",
          "minLength": 1
        },
        "requires_owner_approval": {
          "type": "boolean"
        },
        "owner_approval_proof": {
          "type": "string"
        },
        "rollback_plan": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "if": {
    "properties": {
      "task": {
        "properties": {
          "risk_level": {
            "enum": ["HIGH", "CRITICAL"]
          }
        },
        "required": ["risk_level"]
      }
    }
  },
  "then": {
    "properties": {
      "task": {
        "properties": {
          "requires_owner_approval": {
            "const": true
          }
        },
        "required": ["requires_owner_approval"]
      }
    }
  }
}
