{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Candidate Placement Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "placement_review_result"
  ],
  "properties": {
    "placement_review_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "exit_code",
        "reviewed",
        "eligible_for_downstream_placement",
        "eligible_as_m54_queue_materialization_input",
        "eligible_as_m54_active_task_proposal_input",
        "checked_candidate_id",
        "source_m52_completion_review",
        "source_m52_validation_result",
        "source_generated_artifact",
        "source_traceability",
        "carry_forward",
        "placement_findings",
        "warnings",
        "blockers",
        "boundary_flags",
        "non_authority_markers",
        "m54_independent_validation_required",
        "m54_may_not_start_without_own_gate",
        "m54_materialization_authorized",
        "queue_placement_performed",
        "active_task_replacement_performed",
        "approval_created"
      ],
      "properties": {
        "result": {
          "type": "string",
          "enum": [
            "PLACEMENT_REVIEW_ELIGIBLE",
            "PLACEMENT_REVIEW_ELIGIBLE_WITH_LIMITATIONS",
            "PLACEMENT_REVIEW_NOT_ELIGIBLE",
            "PLACEMENT_REVIEW_BLOCKED"
          ]
        },
        "exit_code": {
          "type": "integer",
          "enum": [
            0,
            1,
            2
          ]
        },
        "reviewed": {
          "type": "boolean"
        },
        "eligible_for_downstream_placement": {
          "type": "boolean"
        },
        "eligible_as_m54_queue_materialization_input": {
          "type": "boolean"
        },
        "eligible_as_m54_active_task_proposal_input": {
          "type": "boolean"
        },
        "checked_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "source_m52_completion_review": {
          "const": "reports/m52-completion-review.md"
        },
        "source_m52_validation_result": {
          "type": "string",
          "minLength": 1
        },
        "source_generated_artifact": {
          "type": "string",
          "minLength": 1
        },
        "source_traceability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_proposal",
            "source_authorization",
            "source_conversion_package",
            "source_generated_artifact",
            "m50_traceability",
            "m51_generator_evidence",
            "m52_validation_evidence"
          ],
          "properties": {
            "source_proposal": {
              "type": "string"
            },
            "source_authorization": {
              "type": "string"
            },
            "source_conversion_package": {
              "type": "string"
            },
            "source_generated_artifact": {
              "type": "string"
            },
            "m50_traceability": {
              "type": "string"
            },
            "m51_generator_evidence": {
              "type": "string"
            },
            "m52_validation_evidence": {
              "type": "string"
            }
          }
        },
        "carry_forward": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "accepted_limitations",
            "warnings",
            "open_questions",
            "downstream_limits",
            "known_gaps",
            "non_authority_boundary"
          ],
          "properties": {
            "accepted_limitations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "open_questions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "downstream_limits": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "known_gaps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "non_authority_boundary": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          }
        },
        "placement_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "boundary_flags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "review_only",
            "queue_write_allowed",
            "active_task_write_allowed",
            "execution_authorized",
            "approval_record_creation_allowed",
            "lifecycle_mutation_allowed",
            "m54_materialization_authorized"
          ],
          "properties": {
            "review_only": {
              "const": true
            },
            "queue_write_allowed": {
              "const": false
            },
            "active_task_write_allowed": {
              "const": false
            },
            "execution_authorized": {
              "const": false
            },
            "approval_record_creation_allowed": {
              "const": false
            },
            "lifecycle_mutation_allowed": {
              "const": false
            },
            "m54_materialization_authorized": {
              "const": false
            }
          }
        },
        "non_authority_markers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "m54_independent_validation_required": {
          "const": true
        },
        "m54_may_not_start_without_own_gate": {
          "const": true
        },
        "m54_materialization_authorized": {
          "const": false
        },
        "queue_placement_performed": {
          "const": false
        },
        "active_task_replacement_performed": {
          "const": false
        },
        "approval_created": {
          "const": false
        }
      }
    }
  }
}
