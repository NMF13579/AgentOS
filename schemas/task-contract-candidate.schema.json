{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-contract-candidate.schema.json",
  "title": "TaskContractCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_contract_candidate"
  ],
  "properties": {
    "task_contract_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "source_proposal",
        "source_authorization",
        "mode",
        "goal",
        "scope",
        "allowed_changes",
        "forbidden_changes",
        "validation",
        "expected_final_report",
        "carry_forward",
        "boundaries"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "source_proposal": {
          "type": "string",
          "minLength": 1
        },
        "source_authorization": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "EXECUTION_SHAPE"
          ]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "allowed_changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_final_report": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "carry_forward": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "accepted_limitations",
            "open_questions",
            "downstream_limits",
            "non_authority_boundary"
          ],
          "properties": {
            "accepted_limitations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "open_questions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "downstream_limits": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "non_authority_boundary": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conversion_validated",
            "executable_contract_shape",
            "candidate_ready_for_placement_review",
            "placement_review_required",
            "execution_authorized",
            "execution_permission_granted",
            "active_task_allowed",
            "task_queue_allowed"
          ],
          "properties": {
            "conversion_validated": {
              "type": "boolean",
              "const": true
            },
            "executable_contract_shape": {
              "type": "boolean",
              "const": true
            },
            "candidate_ready_for_placement_review": {
              "type": "boolean",
              "const": true
            },
            "placement_review_required": {
              "type": "boolean",
              "const": true
            },
            "execution_authorized": {
              "type": "boolean",
              "const": false
            },
            "execution_permission_granted": {
              "type": "boolean",
              "const": false
            },
            "active_task_allowed": {
              "type": "boolean",
              "const": false
            },
            "task_queue_allowed": {
              "type": "boolean",
              "const": false
            }
          }
        }
      }
    }
  }
}
