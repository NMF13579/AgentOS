{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["result_claim", "evidence_binding"],
  "properties": {
    "result_claim": {"type": "string"},
    "evidence_binding": {
      "type": "object",
      "required": ["bound_artifacts", "binding_hash", "generated_by", "validation_source_id"],
      "properties": {
        "bound_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string"},
              "sha256": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"}
            }
          }
        },
        "binding_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
        "generated_by": {
          "type": "string",
          "enum": ["trusted-evaluator", "runner", "validator-wrapper", "agent"]
        },
        "validation_source_id": {"type": "string"}
      }
    }
  }
}
