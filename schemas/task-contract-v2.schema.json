{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.local/schemas/task-contract-v2.schema.json",
  "title": "Task Contract v2",
  "description": "Task Contract validity does not authorize execution. HumanApprovalGate remains separate. Queue placement is not approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "task_id",
    "source_spec",
    "source_ux",
    "source_ui_contract",
    "goal",
    "expected_result",
    "in_scope",
    "out_of_scope",
    "affected_paths",
    "forbidden_paths",
    "dependencies",
    "blocked_by",
    "priority",
    "risk_level",
    "risk_reason",
    "acceptance_criteria",
    "validation_plan",
    "rollback_plan",
    "human_approval_required",
    "owner_review_required",
    "context_required",
    "created_at"
  ],
  "properties": {
    "contract_version": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "source_spec": { "type": "string", "minLength": 1 },
    "source_ux": { "type": "string", "minLength": 1 },
    "source_ui_contract": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "expected_result": { "type": "string", "minLength": 1 },
    "in_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "affected_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_by": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "priority": {
      "type": "string",
      "enum": ["high", "normal", "low"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "risk_reason": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_plan": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rollback_plan": {
      "description": "Required rollback metadata. MEDIUM/HIGH/CRITICAL risk tasks require rollback planning.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "human_approval_required": {
      "type": "boolean",
      "description": "Task Contract validity does not authorize execution. HumanApprovalGate remains separate."
    },
    "owner_review_required": {
      "type": "boolean",
      "description": "Owner review is metadata, not execution approval."
    },
    "context_required": {
      "type": "boolean",
      "description": "context_required only records whether context is required. context_required does not define Context Pack content in this schema version."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "risk_level": { "const": "HIGH" } },
        "required": ["risk_level"]
      },
      "then": {
        "properties": { "human_approval_required": { "const": true } },
        "required": ["human_approval_required"]
      }
    },
    {
      "if": {
        "properties": { "risk_level": { "const": "CRITICAL" } },
        "required": ["risk_level"]
      },
      "then": {
        "properties": {
          "human_approval_required": { "const": true },
          "owner_review_required": { "const": true }
        },
        "required": ["human_approval_required", "owner_review_required"]
      }
    }
  ]
}
